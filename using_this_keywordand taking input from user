import java.util.Scanner ;
 class Student {
 	String name;
 	int regNo;
 	int rollNo;
 	String college;
 	double gpa;
 	String ph_no;
 	
 	Student (String name, int regNo, int rollNo, String college,double gpa, String ph_no){
 		
 		this.name=name;
 		this.regNo=regNo;
 		this.rollNo=rollNo;
 		this.college=college;
 		this.gpa=gpa;
 		this.ph_no=ph_no;
 	}
 	void display(){
 		System.out.println("Name"+name);
 		System.out.println("Registration Number"+regNo);
 		System.out.println("Roll Number"+rollNo);
 		System.out.println("College Name"+college);
 		System.out.println("GPA IN HSC "+gpa);
 		System.out.println("Phone Number"+ph_no);
 	}
 	}
 	
public class Main {
	public static void main(String[] args) {
		
		Scanner input = new Scanner(System.in);
		String name = input.nextLine();
		int regNo= input.nextInt();
		int rollNo= input.nextInt();
		 input.nextLine();
		String college =input.nextLine();
		double gpa = input.nextDouble();
		  input.nextLine();
		String ph_no= input.nextLine();
		Student eww= new Student(name, regNo,rollNo,college,gpa,ph_no);
		eww.display();
		input.close();
	}
}
